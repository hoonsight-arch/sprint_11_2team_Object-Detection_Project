# app_wrapper.py
import streamlit as st
import os
import io
import cv2
import numpy as np
from PIL import Image
from ultralytics import YOLO


DEFAULT_MODEL_PATH = os.path.abspath(
    os.path.join(os.path.dirname(__file__), "..", "github", "baseline", "outputs", "yolo", "train_m", "weights", "best.pt")
)


class PillPredictorWrapper:
    def __init__(self, model_type="YOLO", pth_path=DEFAULT_MODEL_PATH):
        if not os.path.exists(pth_path):
            print(f"⚠️ [WARN] {pth_path} 가중치 파일이 없어 기본 yolov8n.pt를 로드합니다.")
            pth_path = "yolov8n.pt"

        self.model = YOLO(pth_path)
        self.model_type = model_type
        print(f"✅ [INIT] PillPredictorWrapper가 {pth_path} 모델로 초기화되었습니다.")

    def predict(self, image_bytes):
        print("🚀 [DEBUG] PillPredictorWrapper.predict() 가 작동 중입니다!")
        try:
            img = Image.open(io.BytesIO(image_bytes))
            img_cv = cv2.cvtColor(np.array(img), cv2.COLOR_RGB2BGR)

            results_list = self.model(img_cv, verbose=False)
            results = results_list[0]

            refined_output = []
            for box in results.boxes:
                x1, y1, x2, y2 = box.xyxy[0].tolist()
                label = results.names[int(box.cls[0])]
                conf = float(box.conf[0])
                refined_output.append({
                    "box": [int(x1), int(y1), int(x2), int(y2)],
                    "label": label,
                    "confidence": round(conf, 4)
                })

            out_image = results.plot()
            out_image_rgb = cv2.cvtColor(out_image, cv2.COLOR_BGR2RGB)
            return refined_output, out_image_rgb

        except Exception as e:
            print(f"❌ [Wrapper Error] 추론 중 에러 발생: {e}")
            try:
                fallback_img = Image.open(io.BytesIO(image_bytes))
                return [], np.array(fallback_img)
            except:
                return [], None


@st.cache_resource
def load_yolo_model_cached():
    print("[LOG] @st.cache_resource: YOLO 모델 최초 로드 시작...")
    wrapper = PillPredictorWrapper()
    print("[LOG] @st.cache_resource: YOLO 모델 로드 완료, 캐시에 상주합니다.")
    return wrapper


def init_session_state():
    """앱 구동에 필요한 핵심 상태 변수 초기화"""
    if "step" not in st.session_state:
        st.session_state.step = "CAMERA_INPUT"  # CAMERA_INPUT -> AI_ANALYSIS -> EXPANDED_INFO
    if "captured_img" not in st.session_state:
        st.session_state.captured_img = None
    if "feedback_submitted" not in st.session_state:
        st.session_state.feedback_submitted = False

def main():
    # 1. 페이지 기본 설정 (모바일 뷰 최적화 및 다크 테마 기반 지정)
    st.set_page_config(
        page_title="Pill Recognition MVP",
        page_icon="💊",
        layout="centered",
        initial_sidebar_state="collapsed"
    )
    
    # 2. 세션 상태 초기화 보호 계층
    init_session_state()
    
    # 3. 메인 애플리케이션 모듈 호출
    # 주작업 파일인 streamlit_app.py의 로직을 안전하게 로드합니다.
    try:
        import streamlit_app
        streamlit_app.run_app()
    except ModuleNotFoundError:
        st.error("오류: 'streamlit_app.py' 파일을 찾을 수 없습니다. 동일한 디렉토리에 위치시켜주세요.")

if __name__ == "__main__":
    main()

#======================================= YOLO 모델 래퍼 예시 (참고용, 실제로는 streamlit_app.py에서 import하여 사용)

